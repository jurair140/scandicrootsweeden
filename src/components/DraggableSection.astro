---
// src/components/DraggableSection.astro
import berlinImg from "../assets/destination-berlin.png";
import stockholmImg from "../assets/destination-stockholm.png";
import professionalsImg from "../assets/placed-professionals.png";
import careerImg from "../assets/career-path.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isDe = lang === "de";

const polaroids = [
  { img: berlinImg.src, label: isDe ? "Berlin" : "Berlin, DE", rotation: -5, top: 120, left: 100 },
  { img: stockholmImg.src, label: isDe ? "Stockholm" : "Stockholm, SE", rotation: 8, top: 100, left: 140 },
  { img: professionalsImg.src, label: isDe ? "Fachkräfte" : "Placed Talent", rotation: -12, top: 130, left: 110 },
  { img: careerImg.src, label: isDe ? "Karriereweg" : "Career Success", rotation: 15, top: 140, left: 80 },
  { img: berlinImg.src, label: isDe ? "Ihre Zukunft" : "Your Future", rotation: 3, top: 110, left: 130 },
  { img: stockholmImg.src, label: isDe ? "Relocation" : "Relocation", rotation: -8, top: 125, left: 120 },
  { img: professionalsImg.src, label: isDe ? "Exzellenz" : "Excellence", rotation: 10, top: 115, left: 90 },
  { img: careerImg.src, label: isDe ? "Wachstum" : "Growth", rotation: -4, top: 135, left: 150 },
  { img: berlinImg.src, label: isDe ? "Innovation" : "Innovation", rotation: -2, top: 118, left: 125 },
  { img: professionalsImg.src, label: isDe ? "Partnerschaft" : "Partnership", rotation: 6, top: 105, left: 115 },
];
---

<section class="draggable-section section">
  <div class="container draggable-flex">
    <div class="draggable-area" id="drag-container">
      <div class="drag-hint">
        <div class="hint-circle">{t('home.draggable.hint')}</div>
      </div>

      <div class="quote-reveal">
        <blockquote set:html={t('home.draggable.quote')}>
        </blockquote>
        <cite>{t('home.draggable.cite')}</cite>
      </div>
      
      {polaroids.map((p, index) => (
        <div 
          class="polaroid" 
          style={`top: ${p.top}px; left: ${p.left}px; transform: rotate(${p.rotation}deg); z-index: ${index + 10};`}
          data-draggable
        >
          <div class="polaroid-image">
            <img src={p.img} alt={p.label} draggable="false" />
          </div>
          <div class="polaroid-label">{p.label}</div>
        </div>
      ))}
    </div>

    <div class="draggable-content">
      <h2 class="section-badge">{t('home.draggable.badge')}</h2>
      <h3 class="section-title text-left">
        <Fragment set:html={t('home.draggable.title')} />
      </h3>
      <p class="description">
        {t('home.draggable.p1')}
      </p>
      <p class="description">
        {t('home.draggable.p2')}
      </p>
      <div class="btn-group">
        <a href={isDe ? "/de/contact" : "/contact"} class="btn btn-primary">{t('home.draggable.cta.primary')}</a>
        <a href={isDe ? "/de/services" : "/services"} class="btn btn-outline">{t('home.draggable.cta.secondary')}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .draggable-section {
    background-color: #fcfcfc;
    overflow: hidden;
    padding: 10rem 0;
  }

  .draggable-flex {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .draggable-area {
    position: relative;
    height: 500px;
    background: radial-gradient(circle at center, rgba(17, 24, 76, 0.03) 0%, transparent 70%);
    border-radius: 30px;
    border: 2px dashed rgba(17, 24, 76, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quote-reveal {
    position: absolute;
    width: 320px; /* Matching the width of a polaroid for better hiding */
    text-align: center;
    z-index: 2;
    pointer-events: none;
    opacity: 1; /* More visible when revealed */
    user-select: none;
  }

  .quote-reveal blockquote {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem; /* Slightly smaller for a tighter fit */
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.1;
    margin-bottom: 0.8rem;
  }

  .quote-reveal cite {
    font-style: normal;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
  }

  .drag-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 50; /* Above initial cards */
    pointer-events: none;
  }

  .hint-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(17, 24, 76, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(17, 24, 76, 0.1);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
    100% { transform: scale(1); opacity: 0.5; }
  }

  .polaroid {
    position: absolute;
    background: white;
    padding: 12px 12px 40px 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15); /* More pronounced shadow */
    border-radius: 4px;
    cursor: grab;
    user-select: none;
    transition: box-shadow 0.3s ease;
    width: 240px;
  }

  .polaroid::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.02); /* Slight paper texture feel */
    pointer-events: none;
  }

  .polaroid:active {
    cursor: grabbing;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
    transform: scale(1.05) rotate(0deg) !important;
  }

  .polaroid-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #eee;
    border: 1px solid #eee;
  }

  .polaroid-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .polaroid-label {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    color: var(--color-primary);
    text-align: center;
    margin-top: 15px;
    font-size: 1rem;
  }

  .draggable-content {
    padding-right: 2rem;
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .btn-group {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  @media (max-width: 1024px) {
    .draggable-flex {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .draggable-area {
      order: 2;
      height: 400px;
    }
    .draggable-content {
      order: 1;
      text-align: center;
      padding-right: 0;
    }
    .btn-group {
      justify-content: center;
    }
    .text-left {
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .polaroid {
      width: 180px;
    }
    .draggable-area {
      height: 350px;
    }
  }
</style>

<script>
  function initDraggable() {
    const container = document.getElementById('drag-container');
    const cards = document.querySelectorAll('[data-draggable]');
    if (!container || !cards.length) return;

    let zIndex = 100;

    cards.forEach(cardElement => {
      const card = cardElement as HTMLElement;
      let isDragging = false;
      let startX: number, startY: number, initialLeft: number, initialTop: number;

      card.addEventListener('pointerdown', ((e: PointerEvent) => {
        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        
        // Hide hint on interaction
        const hint = document.querySelector('.drag-hint') as HTMLElement;
        if (hint) hint.style.opacity = '0';
        
        const rect = card.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        
        initialLeft = rect.left - containerRect.left;
        initialTop = rect.top - containerRect.top;
        
        card.style.zIndex = (++zIndex).toString();
        card.setPointerCapture(e.pointerId);
      }) as EventListener);

      card.addEventListener('pointermove', ((e: PointerEvent) => {
        if (!isDragging) return;
        
        const dx = e.clientX - startX;
        const dy = e.clientY - startY;
        
        card.style.left = `${initialLeft + dx}px`;
        card.style.top = `${initialTop + dy}px`;
      }) as EventListener);

      card.addEventListener('pointerup', ((e: PointerEvent) => {
        isDragging = false;
        card.releasePointerCapture(e.pointerId);
      }) as EventListener);
    });
  }

  // Initialize on load
  initDraggable();
  
  // Re-init on Astro transition if needed
  document.addEventListener('astro:page-load', initDraggable);
</script>
