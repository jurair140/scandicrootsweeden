---
// src/components/DraggableSection.astro
import uni1 from "../assets/uni_heidelberg.png";
import uni2 from "../assets/uni_munich.png";
import uni3 from "../assets/uni_excellence.png";
import nurse1 from "../assets/nurse_pro.png";
import nurse2 from "../assets/nurse_team.png";
import healthcare from "../assets/healthcare_tech.png";
import ausbildung from "../assets/ausbildung_trainee.png";
import opportunity from "../assets/opportunity_success.png";
import industry from "../assets/industrial_talent.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isDe = lang === "de";

const polaroids = [
  {
    img: industry.src,
    label: t("draggable.label.industry"),
    rotation: -10,
    top: 160,
    left: 120,
  },

  {
    img: uni1.src,
    label: t("draggable.label.uni1"),
    rotation: -5,
    top: 100,
    left: 80,
  },
  {
    img: nurse1.src,
    label: t("draggable.label.nurses1"),
    rotation: 15,
    top: 150,
    left: 90,
  },
  {
    img: uni2.src,
    label: t("draggable.label.uni2"),
    rotation: 8,
    top: 80,
    left: 140,
  },
  {
    img: uni3.src,
    label: t("draggable.label.uni3"),
    rotation: -12,
    top: 130,
    left: 110,
  },

  {
    img: nurse2.src,
    label: t("draggable.label.nurses2"),
    rotation: -8,
    top: 110,
    left: 160,
  },
  {
    img: healthcare.src,
    label: t("draggable.label.healthcare"),
    rotation: 10,
    top: 140,
    left: 130,
  },
  {
    img: ausbildung.src,
    label: t("draggable.label.ausbildung"),
    rotation: -4,
    top: 120,
    left: 60,
  },
  {
    img: opportunity.src,
    label: t("draggable.label.opportunity"),
    rotation: 12,
    top: 90,
    left: 180,
  },
];
---

<section class="draggable-section section">
  <div class="container draggable-flex">
    <div class="draggable-area" id="drag-container">
      <div class="drag-hint">
        <div class="hint-circle">{t("home.draggable.hint")}</div>
      </div>

      <div class="quote-reveal">
        <blockquote set:html={t("home.draggable.quote")} />
        <cite>{t("home.draggable.cite")}</cite>
      </div>

      {
        polaroids.map((p, index) => (
          <div
            class="polaroid"
            style={`top: ${p.top}px; left: ${p.left}px; transform: rotate(${p.rotation}deg); z-index: ${index + 10};`}
            data-draggable
          >
            <div class="polaroid-image">
              <img src={p.img} alt={p.label} draggable="false" />
            </div>
            <div class="polaroid-label">{p.label}</div>
          </div>
        ))
      }
    </div>

    <div class="draggable-content">
      <h2 class="section-badge">{t("home.draggable.badge")}</h2>
      <h3 class="section-title text-left">
        <Fragment set:html={t("home.draggable.title")} />
      </h3>
      <p class="description">
        {t("home.draggable.p1")}
      </p>
      <p class="description">
        {t("home.draggable.p2")}
      </p>
      <div class="btn-group">
        <button type="button" class="btn btn-primary partner-modal-trigger"
          >{t("home.draggable.cta.primary")}</button
        >
        <a href={isDe ? "/services" : "/en/services"} class="btn btn-outline"
          >{t("home.draggable.cta.secondary")}</a
        >
      </div>
    </div>
  </div>
</section>

<style>
  .draggable-section {
    background-color: #fcfcfc;
    overflow: hidden;
    padding: 10rem 0;
  }

  .draggable-flex {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .draggable-area {
    position: relative;
    height: 500px;
    background: radial-gradient(
      circle at center,
      rgba(17, 24, 76, 0.03) 0%,
      transparent 70%
    );
    border-radius: 30px;
    border: 2px dashed rgba(17, 24, 76, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quote-reveal {
    position: absolute;
    width: 320px; /* Matching the width of a polaroid for better hiding */
    text-align: center;
    z-index: 2;
    pointer-events: none;
    opacity: 1; /* More visible when revealed */
    user-select: none;
  }

  .quote-reveal blockquote {
    font-family: "Outfit", sans-serif;
    font-size: 1.5rem; /* Slightly smaller for a tighter fit */
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.1;
    margin-bottom: 0.8rem;
  }

  .quote-reveal cite {
    font-style: normal;
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
  }

  .drag-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 50; /* Above initial cards */
    pointer-events: none;
  }

  .hint-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(17, 24, 76, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(17, 24, 76, 0.1);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.8;
    }
    100% {
      transform: scale(1);
      opacity: 0.5;
    }
  }

  .polaroid {
    position: absolute;
    background: white;
    padding: 12px 12px 40px 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    border-radius: 4px;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none; /* CRITICAL: prevents browser scroll hijacking touch events */
    will-change: left, top; /* GPU-composited movement */
    transition: box-shadow 0.3s ease;
    width: 240px;
  }

  .polaroid::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.02); /* Slight paper texture feel */
    pointer-events: none;
  }

  .polaroid:active {
    cursor: grabbing;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
    transform: scale(1.05) rotate(0deg) !important;
  }

  .polaroid-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #eee;
    border: 1px solid #eee;
  }

  .polaroid-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .polaroid-label {
    font-family: "Outfit", sans-serif;
    font-weight: 600;
    color: var(--color-primary);
    text-align: center;
    margin-top: 15px;
    font-size: 1rem;
  }

  .draggable-content {
    padding-right: 2rem;
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .btn-group {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  @media (max-width: 1024px) {
    .draggable-flex {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .draggable-area {
      order: 2;
      height: 400px;
    }
    .draggable-content {
      order: 1;
      text-align: center;
      padding-right: 0;
    }
    .btn-group {
      justify-content: center;
    }
    .text-left {
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .polaroid {
      width: 180px;
    }
    .draggable-area {
      height: 350px;
    }
  }
</style>

<script>
  function initDraggable() {
    const container = document.getElementById("drag-container");
    const cards = document.querySelectorAll("[data-draggable]");
    if (!container || !cards.length) return;

    let zIndex = 100;

    cards.forEach((cardElement) => {
      const card = cardElement as HTMLElement;
      let isDragging = false;
      let startX: number,
        startY: number,
        initialLeft: number,
        initialTop: number;

      card.addEventListener("pointerdown", ((e: PointerEvent) => {
        // Prevent long-press context menu on iOS/Android
        e.preventDefault();

        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;

        // Hide hint on first interaction
        const hint = document.querySelector(".drag-hint") as HTMLElement;
        if (hint) hint.style.opacity = "0";

        const rect = card.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();

        initialLeft = rect.left - containerRect.left;
        initialTop = rect.top - containerRect.top;

        // Snap position so card doesn't jump on first move
        card.style.left = `${initialLeft}px`;
        card.style.top = `${initialTop}px`;
        card.style.transform = `rotate(0deg)`;
        card.style.zIndex = (++zIndex).toString();

        // Suppress child pointer events during drag to prevent image interference
        card.querySelectorAll("img, div").forEach((el) => {
          (el as HTMLElement).style.pointerEvents = "none";
        });

        card.setPointerCapture(e.pointerId);
      }) as EventListener);

      card.addEventListener("pointermove", ((e: PointerEvent) => {
        if (!isDragging) return;
        e.preventDefault();

        const dx = e.clientX - startX;
        const dy = e.clientY - startY;

        card.style.left = `${initialLeft + dx}px`;
        card.style.top = `${initialTop + dy}px`;
      }) as EventListener);

      const endDrag = (e: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;

        // Restore child pointer events
        card.querySelectorAll("img, div").forEach((el) => {
          (el as HTMLElement).style.pointerEvents = "";
        });

        card.releasePointerCapture(e.pointerId);
      };

      card.addEventListener("pointerup", endDrag as EventListener);
      card.addEventListener("pointercancel", endDrag as EventListener);
    });
  }

  // Initialize on load
  initDraggable();

  // Re-init on Astro transition
  document.addEventListener("astro:page-load", initDraggable);
</script>
