---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import ausbildungImg from "../assets/ausbildung.jpg";
import opportunityImg from "../assets/opportunity.jpg";
import healthcareImg from "../assets/healthcare.jpg";
import industrialImg from "../assets/industrial.jpg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isDe = lang === "de";

const services = [
  {
    id: "ausbildung",
    title: isDe ? "Ausbildung Rekrutierung" : "Ausbildung Recruitment",
    description: isDe
      ? "Verbinden Sie sich mit Deutschlands renommiertem Berufsbildungssystem. Wir helfen Unternehmen, durch internationale Talente eine zukunftssichere Belegschaft aufzubauen."
      : "Connect with Germany's prestigious vocational training system. We help companies build a future-ready workforce through international talent.",
    image: ausbildungImg.src,
    icon: "🎓",
    link: isDe ? "/de/services#ausbildung" : "/services#ausbildung",
    size: "large", // spans 2 cols
  },
  {
    id: "opportunity",
    title: isDe ? "Chancenkarte" : "Opportunity Card",
    description: isDe
      ? "Beschleunigte Einstellung mit Kandidaten, die für das deutsche Chancenkarte-Programm qualifiziert sind."
      : "Fast-track hiring with candidates eligible under Germany's Chancenkarte program.",
    image: opportunityImg.src,
    icon: "🎫",
    link: isDe ? "/de/services#opportunity" : "/services#opportunity",
    size: "small", // spans 1 col
  },
  {
    id: "healthcare",
    title: isDe ? "Gesundheitswesen" : "Healthcare",
    description: isDe
      ? "Qualifizierte internationale Pflegekräfte für europäische Gesundheitseinrichtungen."
      : "Qualified international nurses for European healthcare institutions.",
    image: healthcareImg.src,
    icon: "⚕️",
    link: isDe ? "/de/services#healthcare" : "/services#healthcare",
    size: "small",
  },
  {
    id: "industrial",
    title: isDe ? "Industrielles Personal" : "Industrial Workforce",
    description: isDe
      ? "Fachkräfte für Fertigung, Logistik und technisches Handwerk in ganz Europa. Zuverlässige Pipelines für den Bedarf der Schwerindustrie."
      : "Skilled workers for manufacturing, logistics, and technical trades across Europe. Reliable pipelines for heavy industry needs.",
    image: industrialImg.src,
    icon: "⚙️",
    link: isDe ? "/de/services#industrial" : "/services#industrial",
    size: "large",
  },
];
---

<div class="bento-container">
  <div class="bento-grid">
    {
      services.map((service) => (
        <a href={service.link} class={`bento-card card-${service.size}`}>
          <img src={service.image} alt={service.title} class="card-bg" />
          <div class="card-overlay" />
          <div class="card-content">
            <div class="card-header">
              <span class="card-icon">{service.icon}</span>
              <h3 class="card-title">{service.title}</h3>
            </div>
            <p class="card-description">{service.description}</p>
            <div class="card-footer">
              <span class="learn-more">Explore Program</span>
              <svg
                class="arrow"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
              >
                <path
                  d="M5 12H19"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M12 5L19 12L12 19"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>

<style>
  .bento-container {
    width: 100%;
    margin-top: 2rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 320px;
    gap: 1.5rem;
  }

  .bento-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    color: white;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background-color: #f5f5f5; /* Light fallback */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .card-large {
    grid-column: span 2;
  }

  .card-small {
    grid-column: span 1;
  }

  .card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background-color: var(--color-primary); /* Deep blue fallback */
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(17, 24, 76, 0.2) 0%,
      rgba(17, 24, 76, 0.6) 50%,
      rgba(17, 24, 76, 0.9) 100%
    );
    z-index: 2;
    transition: opacity 0.3s ease;
  }

  .card-content {
    position: relative;
    z-index: 3;
    transform: translateY(20px);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }

  .card-icon {
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .card-title {
    color: white;
    margin: 0;
    font-size: 1.6rem;
    font-weight: 700;
  }

  .card-description {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .arrow {
    transition: transform 0.3s ease;
  }

  /* Hover States */
  .bento-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(17, 24, 76, 0.3);
    border-color: rgba(178, 61, 105, 0.4);
  }

  .bento-card:hover .card-bg {
    transform: scale(1.1);
  }

  .bento-card:hover .card-content {
    transform: translateY(0);
  }

  .bento-card:hover .card-description {
    opacity: 1;
    transform: translateY(0);
  }

  .bento-card:hover .card-footer {
    opacity: 1;
  }

  .bento-card:hover .arrow {
    transform: translateX(5px);
  }

  /* Responsive Styling */
  @media (max-width: 992px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .card-large,
    .card-small {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 280px;
    }
    .card-content {
      transform: translateY(0);
    }
    .card-description {
      opacity: 1;
      transform: translateY(0);
      -webkit-line-clamp: 3;
    }
    .card-footer {
      opacity: 1;
    }
  }
</style>
