---
// src/components/ServiceCard.astro
interface Props {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

const { title, description, icon = "⚡", link = "/services" } = Astro.props;
---

<a href={link} class="card-link">
  <div class="glass-panel service-card">
    <div class="icon-wrapper">
      <span class="icon">{icon}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    
    <div class="card-footer">
      <span class="learn-more">Learn more</span>
      <svg class="arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 12H19" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 5L19 12L12 19" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</a>

<style>
  .card-link {
    display: block;
    height: 100%;
  }

  .service-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #ffffff; /* Base for light theme */
  }

  .icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    background: #FFF1F2; /* very light pink based on accent */
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(178, 61, 105, 0.2);
    transition: all var(--transition-normal);
  }

  .icon {
    font-size: 1.8rem;
  }

  .card-title {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .card-desc {
    font-size: 0.95rem;
    flex-grow: 1;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .card-footer {
    display: flex;
    align-items: center;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.95rem;
    justify-content: space-between;
  }

  .arrow {
    transition: transform var(--transition-normal);
  }

  /* Hover states */
  .service-card:hover .icon-wrapper {
    background: var(--color-accent);
    transform: scale(1.05) rotate(-5deg);
  }

  .service-card:hover .arrow {
    transform: translateX(5px);
  }
</style>
