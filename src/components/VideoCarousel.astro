---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const videos = [
  {
    id: "v1",
    title: "Case Study: Industrial Excellence",
    url: "https://www.youtube.com/embed/gp9vx94Q31g",
  },
  {
    id: "v2",
    title: "Partner Success: Healthcare Talent",
    url: "https://www.youtube.com/embed/gp9vx94Q31g",
  },
  {
    id: "v3",
    title: "Scale-up Success: Logistic Hubs",
    url: "https://www.youtube.com/embed/gp9vx94Q31g",
  },
  {
    id: "v4",
    title: "Corporate Growth: Germany",
    url: "https://www.youtube.com/embed/gp9vx94Q31g",
  },
  {
    id: "v5",
    title: "Talent Acquisition: Nordic Market",
    url: "https://www.youtube.com/embed/gp9vx94Q31g",
  },
];
---

<section class="video-carousel-section section">
  <div class="container relative z-10">
    <div class="section-header">
      <h2 class="section-badge">{t("home.video.title")}</h2>
      <h3 class="section-title">
        <Fragment set:html={t("home.video.subtitle")} />
      </h3>
      <p class="section-desc">
        {t("home.video.desc")}
      </p>
    </div>

    <div class="carousel-viewport">
      <div class="carousel-track" id="video-track">
        {
          videos.map((video, index) => (
            <div class="video-card" data-index={index}>
              <div class="video-wrapper shadow-premium">
                <iframe
                  src={video.url}
                  title={video.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
              <div class="video-label">{video.title}</div>
            </div>
          ))
        }
      </div>

      <button
        class="nav-btn prev-btn"
        id="prev-video"
        aria-label="Previous Success Story"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"><path d="M15 18l-6-6 6-6"></path></svg
        >
      </button>
      <button
        class="nav-btn next-btn"
        id="next-video"
        aria-label="Next Success Story"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"><path d="M9 18l6-6-6-6"></path></svg
        >
      </button>

      <div class="carousel-dots" id="carousel-pagination">
        {
          videos.map((_, index) => (
            <button
              class="dot"
              data-dot={index}
              aria-label={`Go to slide ${index + 1}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .badge-center {
    margin-left: auto;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    margin-bottom: 4rem;
  }

  .section-header .section-desc {
    max-width: 640px;
  }
  .video-carousel-section {
    background-color: #ffffff;
    overflow-x: clip;
    padding: 8rem 0;
  }

  .carousel-viewport {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 0 5rem;
  }

  .carousel-track {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 420px;
    position: relative;
    perspective: 1200px;
  }

  .video-card {
    position: absolute;
    width: min(600px, 55vw);
    height: min(340px, 31vw);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    opacity: 0;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .video-wrapper {
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    border: 4px solid white;
    box-shadow: 0 20px 40px rgba(17, 24, 76, 0.1);
  }

  .video-wrapper iframe {
    width: 100%;
    height: 100%;
  }

  .video-label {
    margin-top: 1.5rem;
    font-family: "Outfit", sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-primary);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Success Active States */
  .video-card.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 10;
    transform: translate(0, 0) scale(1) rotateY(0);
    box-shadow: 0 0 50px rgba(178, 61, 105, 0.2);
  }
  .video-card.active .video-label {
    opacity: 1;
  }

  .video-card.prev {
    opacity: 0.5;
    pointer-events: auto;
    z-index: 5;
    transform: translate(min(-300px, -25vw), 0) scale(0.7) rotateY(20deg);
  }

  .video-card.next {
    opacity: 0.5;
    pointer-events: auto;
    z-index: 5;
    transform: translate(max(300px, 25vw), 0) scale(0.7) rotateY(-20deg);
  }

  .video-card.far-prev {
    opacity: 0.15;
    transform: translate(min(-520px, -42vw), 0) scale(0.5);
  }

  .video-card.far-next {
    opacity: 0.15;
    transform: translate(max(520px, 42vw), 0) scale(0.5);
  }

  /* Nav Buttons */
  .nav-btn {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: white;
    border: 1px solid #eee;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .nav-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-50%) translateY(-3px);
    box-shadow: 0 15px 30px rgba(17, 24, 76, 0.2);
  }

  .prev-btn {
    left: clamp(8px, 2vw, 40px);
  }
  .next-btn {
    right: clamp(8px, 2vw, 40px);
  }

  .nav-btn svg {
    width: 24px;
    height: 24px;
  }

  /* Pagination Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ddd;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    width: 30px;
    background: var(--color-accent);
    border-radius: 10px;
  }

  /* Tablet large */
  @media (max-width: 1024px) {
    .carousel-track {
      height: 340px;
    }
    .video-card {
      width: min(440px, 60vw);
      height: min(248px, 34vw);
    }
    .video-card.prev {
      transform: translate(-190px, 0) scale(0.78) rotateY(18deg);
    }
    .video-card.next {
      transform: translate(190px, 0) scale(0.78) rotateY(-18deg);
    }
    .video-card.far-prev {
      transform: translate(-340px, 0) scale(0.55);
    }
    .video-card.far-next {
      transform: translate(340px, 0) scale(0.55);
    }
  }

  /* Tablet small */
  @media (max-width: 768px) {
    .video-carousel-section {
      padding: 5rem 0;
    }
    .carousel-track {
      height: 280px;
    }
    .video-card {
      width: 72vw;
      height: 40.5vw;
    }
    .video-card.prev {
      transform: translate(-58vw, 0) scale(0.72) rotateY(15deg);
      opacity: 0.35;
    }
    .video-card.next {
      transform: translate(58vw, 0) scale(0.72) rotateY(-15deg);
      opacity: 0.35;
    }
    .video-card.far-prev,
    .video-card.far-next {
      opacity: 0;
      pointer-events: none;
    }
    .nav-btn {
      width: 48px;
      height: 48px;
    }
    .prev-btn {
      left: 6px;
    }
    .next-btn {
      right: 6px;
    }
    .text-center.mb-16 {
      margin-bottom: 2.5rem;
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .video-carousel-section {
      padding: 4rem 0;
    }
    .carousel-track {
      height: 240px;
    }
    .video-card {
      width: 88vw;
      height: 49.5vw;
    }
    .video-card.prev,
    .video-card.next,
    .video-card.far-prev,
    .video-card.far-next {
      opacity: 0;
      pointer-events: none;
    }
    .nav-btn {
      top: 38%;
      width: 38px;
      height: 38px;
    }
    .nav-btn svg {
      width: 18px;
      height: 18px;
    }
    .prev-btn {
      left: 4px;
    }
    .next-btn {
      right: 4px;
    }
    .carousel-dots {
      margin-top: 1.25rem;
      gap: 0.6rem;
    }
    .video-label {
      font-size: 1rem;
      margin-top: 1rem;
    }
  }
</style>

<script>
  function initVideoCarousel() {
    const track = document.getElementById("video-track");
    const cards = document.querySelectorAll(".video-card");
    const dots = document.querySelectorAll(".dot");
    const prevBtn = document.getElementById("prev-video");
    const nextBtn = document.getElementById("next-video");

    if (!track || !cards.length) return;

    let currentIndex = 0;
    const total = cards.length;

    function update() {
      cards.forEach((card, index) => {
        card.className = "video-card";

        if (index === currentIndex) {
          card.classList.add("active");
        } else if (index === (currentIndex - 1 + total) % total) {
          card.classList.add("prev");
        } else if (index === (currentIndex + 1) % total) {
          card.classList.add("next");
        } else if (index === (currentIndex - 2 + total) % total) {
          card.classList.add("far-prev");
        } else if (index === (currentIndex + 2) % total) {
          card.classList.add("far-next");
        }
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle("active", index === currentIndex);
      });
    }

    function next() {
      currentIndex = (currentIndex + 1) % total;
      update();
    }

    function prev() {
      currentIndex = (currentIndex - 1 + total) % total;
      update();
    }

    nextBtn?.addEventListener("click", next);
    prevBtn?.addEventListener("click", prev);

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        currentIndex = parseInt(dot.getAttribute("data-dot") || "0");
        update();
      });
    });

    update();
  }

  // Initialize
  initVideoCarousel();
  document.addEventListener("astro:page-load", initVideoCarousel);
</script>
