---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
---

<Layout
  title="Über uns"
  description="Erfahren Sie mehr über Scandic Roots, unsere Mission, Indien-Allianz und den 5-stufigen Auswahlprozess."
>
  <!-- HERO — SPLIT SCREEN -->
  <section class="ab-hero">
    <div class="ab-hero__left">
      <div class="ab-hero__left-inner">
        <div class="ab-hero__eyebrow">
          <span class="dot"></span>
          <p>
            Gegründet in Schweden. Verwurzelt in Indien. Deutschland Fokussiert.
          </p>
        </div>
        <h1 class="ab-hero__title">
          Wir verbinden<br /><em>Zwei Welten.</em>
        </h1>
        <p class="ab-hero__sub">
          Scandic Roots wurde gegründet, um Deutschlands wachsenden
          Fachkräftemangel durch eine strukturierte, ethische und
          ergebnisorientierte Brücke zwischen indischen Arbeitskräften und
          deutschen Arbeitgebern zu lösen.
        </p>
        <div class="ab-hero__btns">
          <a href="/de/services" class="btn-glow"
            >Unsere Programme <i class="fa-solid fa-arrow-right"></i></a
          >
          <a href="/de/contact" class="btn-ghost">Kontaktieren Sie uns</a>
        </div>
      </div>
    </div>
    <div class="ab-hero__right">
      <div class="ab-hero__map-bg"><div class="ab-hero__glow"></div></div>
      <div class="ab-stat-grid">
        <div class="ab-stat">
          <i class="fa-solid fa-passport"></i><span class="ab-stat__num">4</span
          ><span class="ab-stat__label">Kernprogramme</span>
        </div>
        <div class="ab-stat ab-stat--accent">
          <i class="fa-solid fa-plane-departure"></i><span class="ab-stat__flag"
            >🇮🇳 to 🇩🇪</span
          ><span class="ab-stat__label">Indien nach Deutschland</span>
        </div>
        <div class="ab-stat">
          <i class="fa-solid fa-filter"></i><span class="ab-stat__num">5</span
          ><span class="ab-stat__label">Stufen Screening</span>
        </div>
        <div class="ab-stat">
          <i class="fa-solid fa-building-user"></i><span class="ab-stat__num"
            >15+</span
          ><span class="ab-stat__label">Branchen</span>
        </div>
      </div>
      <div class="ab-tri-flags">
        <div class="ab-flag-node">
          <span>🇸🇪</span><small>Hauptsitz Schweden</small>
        </div>
        <div class="ab-flag-node">
          <span>🇮🇳</span><small>Indien Netzwerk</small>
        </div>
        <div class="ab-flag-node">
          <span>🇩🇪</span><small>Deutschland Fokus</small>
        </div>
      </div>
    </div>
  </section>

  <!-- WER WIR SIND -->
  <section class="who-we-are">
    <div class="container">
      <div class="wwa__inner">
        <aside class="wwa__sidebar">
          <span class="section-badge"
            ><i class="fa-solid fa-book-open"></i> Unsere Geschichte</span
          >
          <h2>
            Eine Tri-Länder <span class="text-gradient">Workforce-Brücke</span>
          </h2>
          <div class="wwa__sidebar-cards">
            <div class="wwa__country-card">
              <div class="wwa__country-icon">
                <i class="fa-solid fa-map-location-dot"></i>
              </div>
              <h4>Hauptsitz in Schweden</h4>
              <p>
                Mit skandinavischer Präzision und Zugang zu nordischen und
                deutschen Arbeitsmärkten tätig.
              </p>
            </div>
            <div class="wwa__country-card wwa__country-card--featured">
              <div class="wwa__country-icon">
                <i class="fa-solid fa-building-flag"></i>
              </div>
              <h4>Deutschland Fokus</h4>
              <p>
                Tiefes Fachwissen in deutschem Arbeitsrecht, Visawegen und
                Personalintegration.
              </p>
            </div>
            <div class="wwa__country-card">
              <div class="wwa__country-icon">
                <i class="fa-solid fa-handshake-simple"></i>
              </div>
              <h4>Indien Talentpartnerschaft</h4>
              <p>
                Institutionelle Partnerschaften mit Zugang zu einem breiten,
                qualifizierten indischen Kandidatenpool.
              </p>
            </div>
          </div>
        </aside>
        <div class="wwa__text">
          <p class="wwa__text-large">
            Scandic Roots wurde mit einer einzigen klaren Vision gegründet,
            Deutschlands sich beschleunigenden Fachkräftemangel durch einen
            prozessorientierten, ethischen und zutiefst persönlichen Ansatz zu
            lösen.
          </p>

          <div
            class="wwa__eu-notice"
            style="background: rgba(178, 61, 105, 0.05); border: 1px solid rgba(178, 61, 105, 0.1); border-left: 4px solid var(--rose); padding: 1.5rem; border-radius: 8px; margin: 2rem 0;"
          >
            <div style="display: flex; align-items: flex-start; gap: 1rem;">
              <i
                class="fa-solid fa-building-shield"
                style="color: var(--rose); font-size: 1.5rem; margin-top: 0.1rem;"
              ></i>
              <div>
                <h4
                  style="margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--indigo);"
                >
                  EU-Etablierte Operationen
                </h4>
                <p
                  style="margin: 0; font-size: 0.95rem; line-height: 1.6; color: var(--muted);"
                >
                  Scandic Roots ist ein <strong
                    >in Slowenien registriertes</strong
                  > Unternehmen für Unternehmensberatung und die Vermittlung qualifizierter
                  Arbeitskräfte. Wir widmen uns der Unterstützung europäischer Unternehmen
                  mit vollständig konformen Personallösungen, spezialisiert auf den
                  Schiffbau, das Baugewerbe und den Transport &amp; Logistiksektor.
                </p>
              </div>
            </div>
          </div>

          <p>
            Mit Hauptsitz in Schweden und tiefen Wurzeln in Indien und
            Deutschland bringen wir eine einzigartige
            Mehrechtsprechungs-Perspektive ein. Unser Team versteht die Nuancen
            des deutschen Arbeitsrechts, die Komplexität indischer
            Bildungsnachweise und die kulturelle Integration für langfristigen
            Erfolg.
          </p>
          <p>
            Wir bieten vier Wege an: die <strong>Chancenkarte</strong>, <strong
              >Pflegekräfte Rekrutierung</strong
            >, <strong>Ausbildungsvermittlung</strong> und <strong
              >Internationale Fachkräfte Rekrutierung</strong
            >.
          </p>
          <div class="wwa__divider"></div>
          <div class="wwa__bullets">
            <div class="wwa__bullet">
              <i class="fa-solid fa-circle-check"></i><span
                >Keine versteckten Gebühren, volle Transparenz für Kandidaten.</span>
            </div>
            <div class="wwa__bullet">
              <i class="fa-solid fa-circle-check"></i><span
                >Vollständige Einhaltung deutscher und EU Recruitingstandards.</span>
            </div>
            <div class="wwa__bullet">
              <i class="fa-solid fa-circle-check"></i><span
                >Unterstützung nach der Vermittlung bis zur langfristigen
                Integration.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION & WERTE -->
  <section class="values-section">
    <div class="container">
      <div class="values-section__header">
        <span class="section-badge section-badge--light"
          ><i class="fa-solid fa-gem"></i> Was uns antreibt</span
        >
        <h2>
          Mission <span class="text-gradient-light">&amp; Kernwerte</span>
        </h2>
        <p>
          Jede Entscheidung wird von diesen Prinzipien geleitet, von der
          Kandidatensuche bis zur Integration nach der Vermittlung.
        </p>
      </div>
      <div class="values-masonry">
        <div class="val-card val-card--big">
          <div class="val-card__icon"><i class="fa-solid fa-bullseye"></i></div>
          <h3>Unsere Mission</h3>
          <p>
            Deutschen Arbeitgebern zuverlässige, professionell geprüfte und
            sprachlich vorbereitete Kandidaten aus Indien zu vermitteln,
            während indischen Fachkräften ein strukturierter, ethischer Weg in
            eine bessere Zukunft in Deutschland eröffnet wird.
          </p>
        </div>
        <div class="val-card">
          <div class="val-card__icon">
            <i class="fa-solid fa-magnifying-glass-chart"></i>
          </div>
          <h3>Präzises Matching</h3>
          <p>
            Jeder Kandidat wird auf Fähigkeiten, Sprachkenntnisse, kulturelle
            Passung und Compliance bewertet.
          </p>
        </div>
        <div class="val-card">
          <div class="val-card__icon">
            <i class="fa-solid fa-scale-balanced"></i>
          </div>
          <h3>Ethische Rekrutierung</h3>
          <p>
            Volle Transparenz. Keine versteckten Gebühren. Keine Abkürzungen bei
            der Compliance.
          </p>
        </div>
        <div class="val-card val-card--accent">
          <div class="val-card__icon">
            <i class="fa-solid fa-earth-europe"></i>
          </div>
          <h3>Kulturelle Integration</h3>
          <p>
            Wir bereiten Kandidaten nicht nur auf Arbeit, sondern auch auf das
            Leben in Deutschland vor: Arbeitskultur, europäische Sozialnormen
            und Alltagsregelungen.
          </p>
        </div>
        <div class="val-card">
          <div class="val-card__icon">
            <i class="fa-solid fa-handshake-angle"></i>
          </div>
          <h3>Langfristiges Engagement</h3>
          <p>
            Wir stoppen nicht bei der Vermittlung. Nachbetreuung und
            Orientierungsklassen sichern die Retention.
          </p>
        </div>
        <div class="val-card">
          <div class="val-card__icon">
            <i class="fa-solid fa-chart-line"></i>
          </div>
          <h3>Arbeitskontinuität</h3>
          <p>
            Wir bauen langfristige Talent Pipelines, keine einmaligen
            Vermittlungen, für nachhaltige Stabilität.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- VIER PROGRAMME -->
  <section class="programs-section">
    <div class="container">
      <div class="programs-section__header">
        <span class="section-badge"
          ><i class="fa-solid fa-briefcase"></i> Was wir bieten</span
        >
        <h2>Unsere vier <span class="text-gradient">Kernprogramme</span></h2>
      </div>
      <div class="prog-tracks">
        <div class="prog-track">
          <div class="prog-track__num">01</div>
          <div class="prog-track__icon-wrap">
            <i class="fa-solid fa-passport"></i>
          </div>
          <h3>Chancenkarte <br /><span>(Opportunity Card)</span></h3>
          <p>
            Punktebasierter Aufenthaltstitel für Nicht-EU-Fachkräfte zur
            Jobsuche in Deutschland, bis zu 12 Monate, ohne vorheriges
            Jobangebot.
          </p>
          <ul>
            <li><i class="fa-solid fa-check"></i> Sprachkenntnisbewertung</li>
            <li>
              <i class="fa-solid fa-check"></i> Sperrkonto Unterstützung (12.000 €+)
            </li>
            <li><i class="fa-solid fa-check"></i> Dokumentenvorbereitung</li>
            <li>
              <i class="fa-solid fa-check"></i> Jobsuche-Orientierung nach Ankunft
            </li>
          </ul>
          <a href="/de/services#opportunity"
            >Mehr erfahren <i class="fa-solid fa-arrow-right"></i></a
          >
        </div>
        <div class="prog-track prog-track--featured">
          <div class="prog-track__num">02</div>
          <div class="prog-track__icon-wrap">
            <i class="fa-solid fa-user-nurse"></i>
          </div>
          <h3>
            Pflegekräfte für das<br /><span>Deutsche Gesundheitssystem</span>
          </h3>
          <p>
            Gut qualifizierte, erfahrene und deutschsprachige (B1 bis B2) indische
            Pflegekräfte für Krankenhäuser und Reha Einrichtungen in
            Deutschland.
          </p>
          <ul>
            <li><i class="fa-solid fa-check"></i> B1 bis B2 Deutschkenntnisse</li>
            <li>
              <i class="fa-solid fa-check"></i> Anerkanntes Diplom/Bachelor in Pflege
            </li>
            <li>
              <i class="fa-solid fa-check"></i> Unterstützung zur Berufsanerkennung
            </li>
            <li>
              <i class="fa-solid fa-check"></i> Integrations &amp; Relocation Hilfe
            </li>
          </ul>
          <a href="/de/services#nurses"
            >Mehr erfahren <i class="fa-solid fa-arrow-right"></i></a
          >
        </div>
        <div class="prog-track">
          <div class="prog-track__num">03</div>
          <div class="prog-track__icon-wrap">
            <i class="fa-solid fa-graduation-cap"></i>
          </div>
          <h3>Ausbildungskandidaten <br /><span>Vermittlung</span></h3>
          <p>
            Motivierte indische Kandidaten für Deutschlands duales
            Ausbildungssystem, vorgeprüft, deutschvorbereitet (A2-B1) und
            integrationsbereit.
          </p>
          <ul>
            <li>
              <i class="fa-solid fa-check"></i> Branchenspezifisches Matching
            </li>
            <li>
              <i class="fa-solid fa-check"></i> August bis September und Februar bis März
              Aufnahmen
            </li>
            <li><i class="fa-solid fa-check"></i> Relocation Unterstützung</li>
            <li>
              <i class="fa-solid fa-check"></i> Europäische Sozialorientierung
            </li>
          </ul>
          <a href="/de/services#ausbildung"
            >Mehr erfahren <i class="fa-solid fa-arrow-right"></i></a
          >
        </div>
        <div class="prog-track">
          <div class="prog-track__num">04</div>
          <div class="prog-track__icon-wrap">
            <i class="fa-solid fa-helmet-safety"></i>
          </div>
          <h3>Internationale Fachkräfte <br /><span>Rekrutierung</span></h3>
          <p>
            Erfahrene Arbeitskräfte für Deutschlands Schiffbau-,
            Fleischverarbeitungs- und Industriesektoren, sprachvorbereitet und
            vorgeprüft.
          </p>
          <ul>
            <li>
              <i class="fa-solid fa-check"></i> Schiffbau- &amp; Schweißexperten
            </li>
            <li>
              <i class="fa-solid fa-check"></i> Fleischverarbeitungsprofis
            </li>
            <li>
              <i class="fa-solid fa-check"></i> Industrie- &amp; Logistikarbeiter
            </li>
            <li><i class="fa-solid fa-check"></i> A2 bis B1 Deutschvorbereitung</li>
          </ul>
          <a href="/de/services#skilled"
            >Mehr erfahren <i class="fa-solid fa-arrow-right"></i></a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- INDIEN-ALLIANZ TRAINING -->
  <section class="training-alliance">
    <div class="container">
      <div class="training-alliance__header">
        <span class="section-badge section-badge--light"
          ><i class="fa-solid fa-school-flag"></i> Indien Allianz</span
        >
        <h2>
          Interne <span class="text-gradient-light">Trainingseinrichtung</span>
        </h2>
        <p>
          Durch institutionelle Partnerschaften in Indien betreiben wir eine
          umfassende Vorbereitungseinrichtung, bevor die Kandidaten ins
          Flugzeug steigen.
        </p>
      </div>
      <div class="ta-cards">
        <div class="ta-card ta-card--featured">
          <div class="ta-card__icon"><i class="fa-solid fa-comments"></i></div>
          <h3>Deutschsprachtraining</h3>
          <p>
            Durchgeführt von <strong>muttersprachlichen Deutschen</strong>.
            Unser Training geht weit über die Grundlagen hinaus. Berufssprache,
            Branchenvokabular, Alltagskommunikation auf A1 bis B2 Niveau.
          </p>
          <div class="ta-levels">
            <span>A1</span><span>A2</span><span>B1</span><span>B2</span>
          </div>
        </div>
        <div class="ta-card">
          <div class="ta-card__icon">
            <i class="fa-solid fa-microphone-lines"></i>
          </div>
          <h3>Interview Vorbereitung</h3>
          <p>
            Mock-Interviews, die reale deutschen Arbeitgebergspräche simulieren,
            technische Fragen und professionelle Selbstpräsentation auf
            Deutsch.
          </p>
        </div>
        <div class="ta-card">
          <div class="ta-card__icon"><i class="fa-solid fa-gavel"></i></div>
          <h3>Deutsches Recht &amp; Regelungen</h3>
          <p>
            Arbeitsrecht, Sozialversicherung, Arbeitssicherheit und Wohnrecht
            für Neuankömmlinge in Deutschland.
          </p>
        </div>
        <div class="ta-card">
          <div class="ta-card__icon">
            <i class="fa-solid fa-people-arrows"></i>
          </div>
          <h3>Europäische Sozialnormen</h3>
          <p>
            Orientierungssitzungen zu Sozialetikette, Pünktlichkeit, Hierarchie,
            ÖPNV und Integration in die deutsche Gemeinschaft.
          </p>
        </div>
        <div class="ta-card">
          <div class="ta-card__icon"><i class="fa-solid fa-briefcase"></i></div>
          <h3>Arbeitsplatz Kulturbereitschaft</h3>
          <p>
            Deutsche Werte: Effizienz, Präzision, indirekte Kommunikation,
            professionelle Grenzen, reduzieren Kulturschock und beschleunigen
            Integration.
          </p>
        </div>
        <div class="ta-card">
          <div class="ta-card__icon">
            <i class="fa-solid fa-clipboard-check"></i>
          </div>
          <h3>Dokumenten &amp; Compliance Vorbereitung</h3>
          <p>
            Geführte Vorbereitung von Zeugnissen, polizeilichen
            Führungszeugnissen, Sperrkonto Anforderungen und Visumantrag.
          </p>
        </div>
      </div>
      <div class="ta-pullquote">
        <i class="fa-solid fa-quote-left"></i>
        <blockquote>
          Die meisten Agenturen leiten einfach Lebensläufe weiter.<br /><strong
            >Wir bauen Kandidaten auf.</strong>
        </blockquote>
        <cite>Scandic Roots Trainingsphilosophie</cite>
      </div>
    </div>
  </section>

  <!-- 5-STUFEN VETTING -->
  <section class="vetting-section">
    <div class="container">
      <div class="vetting-section__header">
        <span class="section-badge"
          ><i class="fa-solid fa-filter"></i> Unser Prüfprozess</span
        >
        <h2>Wie wir <span class="text-gradient">Kandidaten auswählen</span></h2>
        <p>
          Unser 5-stufiger Screening-Prozess ist einer der strengsten der
          Branche, jeder Kandidat ist vollständig qualifiziert und compliant.
        </p>
      </div>
      <div class="vet-timeline">
        <div class="vet-item">
          <div class="vet-item__connector-wrap">
            <div class="vet-step"><i class="fa-solid fa-language"></i></div><div
              class="vet-line"
            >
            </div>
          </div>
          <div class="vet-content vet-content--right">
            <span class="vet-num">01</span>
            <h3>Sprachkenntnischeck</h3>
            <p>
              Strukturierte Video oder Präsenz Deutsch Interviews. Beurteilung
              von Sprechflüssigkeit, Verstehen, Schreiben und
              kontextspezifischem Vokabular. Mindestanforderungen je nach
              Programmtyp (A1 für Chancenkarte; A2 bis B1 für Ausbildung und
              Fachkräfte).
            </p>
            <div class="vet-tags">
              <span>Mündliches Interview</span><span>Schriftlicher Test</span
              ><span>Niveauzertifizierung</span>
            </div>
          </div>
        </div>
        <div class="vet-item vet-item--flip">
          <div class="vet-content vet-content--left">
            <span class="vet-num">02</span>
            <h3>Dokumentenverifizierung</h3>
            <p>
              Alle Bildungs- und Berufsqualifikationen werden geprüft und gegen
              deutsche und EU-Anerkennungsrahmen abgeglichen.
              Gleichwertigkeitszuordnungen werden identifiziert.
            </p>
            <div class="vet-tags">
              <span>Abschlussverifizierung</span><span
                >Berufsqualifikationen</span
              ><span>Erfahrungsnachweise</span>
            </div>
          </div>
          <div class="vet-item__connector-wrap">
            <div class="vet-step">
              <i class="fa-solid fa-file-contract"></i>
            </div><div class="vet-line"></div>
          </div>
        </div>
        <div class="vet-item">
          <div class="vet-item__connector-wrap">
            <div class="vet-step vet-step--dark">
              <i class="fa-solid fa-shield-halved"></i>
            </div><div class="vet-line"></div>
          </div>
          <div class="vet-content vet-content--right">
            <span class="vet-num">03</span>
            <h3>Führungszeugnis</h3>
            <p>
              Jeder Kandidat reicht gültige polizeiliche Führungszeugnisse aus
              allen Wohnsitzländern der letzten 10 Jahre ein.
              Nulltoleranzpolitik bei disqualifizierenden Einträgen.
            </p>
            <div class="vet-tags">
              <span>Polizeiliche Bestätigung</span><span
                >Hintergrundprüfung</span
              ><span>Nulltoleranz</span>
            </div>
          </div>
        </div>
        <div class="vet-item vet-item--flip">
          <div class="vet-content vet-content--left">
            <span class="vet-num">04</span>
            <h3>Finanzielle Bonitätsprüfung</h3>
            <p>
              Bei Chancenkarte-Antragstellern prüfen wir das Sperrkonto mit dem
              erforderlichen Guthaben (ca. 12.000 €+) und die allgemeine
              finanzielle Bonität für die Übergangsphase.
            </p>
            <div class="vet-tags">
              <span>Sperrkonto Nachweis</span><span>Finanzaufstellung</span
              ><span>Eigenversorgungscheck</span>
            </div>
          </div>
          <div class="vet-item__connector-wrap">
            <div class="vet-step"><i class="fa-solid fa-wallet"></i></div><div
              class="vet-line"
            >
            </div>
          </div>
        </div>
        <div class="vet-item">
          <div class="vet-item__connector-wrap">
            <div class="vet-step vet-step--final">
              <i class="fa-solid fa-thumbs-up"></i>
            </div>
          </div>
          <div class="vet-content vet-content--right">
            <span class="vet-num">05</span>
            <h3>Abschließende Compliance Freigabe</h3>
            <p>
              Unser Compliance-Team führt eine finale Gesamtprüfung durch:
              Einwanderungseignung, Punktebewertung (für Chancenkarte),
              Visaweg Eignung und arbeitgeberspezifische Anforderungen. Nur
              Kandidaten, die alle fünf Stufen bestehen, werden empfohlen.
            </p>
            <div class="vet-tags">
              <span>Punktesystemprüfung</span><span>Einwanderungsreview</span
              ><span>Arbeitgeberbereit</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM & WARUM WIR -->
  <section class="team-why">
    <div class="container team-why__grid">
      <div class="team-panel">
