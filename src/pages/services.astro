---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
---

<Layout title="Unsere Leistungen" description="Vier spezialisierte Programme, die indische Talente mit deutschen Arbeitsmöglichkeiten verbinden.">

<!-- HERO -->
<section class="sv-hero">
  <div class="sv-hero__noise"></div>
  <div class="sv-hero__glow sv-hero__glow--a"></div>
  <div class="sv-hero__glow sv-hero__glow--b"></div>
  <div class="sv-hero__glow sv-hero__glow--c"></div>
  <div class="container sv-hero__inner">
    <div class="sv-hero__eyebrow">
      <span class="dot"></span>
      <p>Fünf Spezialisierte Programme</p>
      <span class="dot"></span>
    </div>
    <h1 class="sv-hero__title">
      Indische Exzellenz trifft<br /><em>Deutsche Chancen</em>
    </h1>
    <p class="sv-hero__sub">Von Gesundheitswesen bis Industrie, präzise Vermittlung gestützt durch einen 5 stufigen Auswahlprozess, der integrationsbereite Fachkräfte liefert.</p>
    <nav class="sv-hero__nav">
      <a href="/services/opportunity-card" class="sv-nav-pill"><i class="fa-solid fa-passport"></i><span>Chancenkarte</span></a>
      <a href="/services/nurses" class="sv-nav-pill"><i class="fa-solid fa-user-nurse"></i><span>Pflegekräfte</span></a>
      <a href="/services/ausbildung" class="sv-nav-pill"><i class="fa-solid fa-graduation-cap"></i><span>Ausbildung</span></a>
      <a href="/services/studium-zulassung" class="sv-nav-pill"><i class="fa-solid fa-university"></i><span>Studium Zulassung</span></a>
      <a href="/services/skilled-workers" class="sv-nav-pill"><i class="fa-solid fa-helmet-safety"></i><span>Fachkräfte</span></a>
    </nav>
  </div>
  <div class="sv-hero__scroll"><span>Nach unten scrollen</span><i class="fa-solid fa-chevron-down"></i></div>
</section>

<!-- PROGRAMM 01 — PFLEGEKRÄFTE -->

<section class="prg prg--alt" id="nurses">
  <div class="prg__stripe prg__stripe--rose"></div>
  <div class="container prg__grid prg__grid--flip">
    <aside class="prg__anchor">
      <div class="prg__num">01</div>
      <div class="prg__icon-wrap prg__icon-wrap--rose"><i class="fa-solid fa-user-nurse"></i></div>
      <h2 class="prg__title">Indische Pflegekräfte <span class="text-gradient">Rekrutierungsprogramm</span></h2>
      <p class="prg__lead">Gut qualifizierte, erfahrene und deutschsprachige indische Pflegekräfte für Krankenhäuser, Altenpflege und Reha Einrichtungen in Deutschland.</p>
      <a href="/contact" class="btn-glow">Pflegekräfte Einstellen <i class="fa-solid fa-arrow-right"></i></a>
    </aside>
    <div class="prg__cards">
      <div class="info-card">
        <div class="info-card__head"><i class="fa-solid fa-id-badge"></i><h3>Kandidatenprofil</h3></div>
        <ul class="check-list">
          <li>Anerkanntes Diplom oder Bachelor in Pflege</li>
          <li>Einschlägige klinische Erfahrung</li>
          <li>Deutschkenntnisse auf <strong>B1 bis B2 Niveau</strong></li>
          <li>Professionell geprüft auf Anpassungsfähigkeit und langfristige Bindung</li>
        </ul>
      </div>
      <div class="info-card info-card--accent">
        <div class="info-card__head"><i class="fa-solid fa-certificate"></i><h3>Berufsanerkennung</h3></div>
        <p>Wir begleiten den gesamten Anerkennungsprozess in Deutschland. Kandidaten können als <strong>Pflegehilfskräfte</strong> beginnen, während sie Anpassungsprüfungen absolvieren.</p>
      </div>
      <div class="info-card info-card--dark">
        <div class="info-card__head"><i class="fa-solid fa-filter"></i><h3>Vorauswahl &amp; Screening</h3></div>
        <div class="support-pills">
          <span><i class="fa-solid fa-comments"></i> Sprachinterviews</span>
          <span><i class="fa-solid fa-file-contract"></i> Zeugnisverifizierung</span>
          <span><i class="fa-solid fa-shield-halved"></i> Führungszeugnisse</span>
          <span><i class="fa-solid fa-scale-balanced"></i> Compliance Prüfung</span>
          <span><i class="fa-solid fa-calendar-check"></i> Ganzjährig verfügbar</span>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card__head"><i class="fa-solid fa-plane-arrival"></i><h3>Integration &amp; Relocation</h3></div>
        <p>Wir unterstützen Kandidaten bei der Wohnungssuche, Relocation und bieten Orientierungssitzungen zu Sozialregeln, Erwartungen am Arbeitsplatz und Gesundheitssystemkultur.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAMM 02 — AUSBILDUNG -->

<section class="prg-bento" id="ausbildung">
  <div class="container">
    <header class="bento-header">
      <div class="bento-header__meta">
        <div class="prg__num">02</div>
        <div class="prg__icon-wrap prg__icon-wrap--indigo"><i class="fa-solid fa-graduation-cap"></i></div>
      </div>
      <div class="bento-header__text">
        <h2>Indische Ausbildungskandidaten <span class="text-gradient">Vermittlung</span></h2>
        <p>Motivierte, deutschsprachige indische Kandidaten für Deutschlands duales Ausbildungssystem, branchenübergreifend und gut vorbereitet.</p>
      </div>
    </header>
    <div class="bento">
      <div class="bento__cell bento__cell--hero-dark">
        <div class="bento__inner">
          <i class="fa-solid fa-users-between-lines bento__big-icon"></i>
          <h3>Programmübersicht</h3>
          <p>Dieses Programm unterstützt deutsche Unternehmen durch sorgfältig ausgewählte indische Kandidaten für Berufsausbildungen. Wir liefern motivierte und integrationsbereite Auszubildende, die eine langfristige Karriere in Deutschland anstreben.</p>
          <p>Kandidaten werden auf ihre Anpassungsfähigkeit, Verantwortungsbewusstsein und langfristige Ausbildungsentschlossenheit geprüft.</p>
        </div>
      </div>
      <div class="bento__cell">
        <i class="fa-solid fa-id-card bento__cell-icon"></i>
        <h4>Kandidatenprofil</h4>
        <p>Abgeschlossene Sekundarschulbildung, A2 bis B1 Deutsch, hohe motivation für das duale Ausbildungssystem.</p>
      </div>
      <div class="bento__cell bento__cell--accent">
        <i class="fa-solid fa-calendar-check bento__cell-icon"></i>
        <h4>Einstellungsphasen</h4>
        <div class="intake-rows">
          <div class="intake-row intake-row--primary"><span>Hauptphase</span><strong>August bis September</strong></div>
          <div class="intake-row intake-row--secondary"><span>Nebenphase</span><strong>Februar bis März</strong></div>
        </div>
        <p class="intake-note">Ganzjährige Vermittlung nach Arbeitgeberbedarf möglich.</p>
      </div>
      <div class="bento__cell bento__cell--fields">
        <i class="fa-solid fa-layer-group bento__cell-icon"></i>
        <h4>Verfügbare Ausbildungsfelder</h4>
        <div class="field-tags">
          <span><i class="fa-solid fa-stethoscope"></i> Gesundheitswesen</span>
          <span><i class="fa-solid fa-bed"></i> Altenpflege</span>
          <span><i class="fa-solid fa-hotel"></i> Gastronomie</span>
          <span><i class="fa-solid fa-truck"></i> Logistik</span>
          <span><i class="fa-solid fa-wrench"></i> Handwerk</span>
          <span><i class="fa-solid fa-store"></i> Einzelhandel</span>
          <span><i class="fa-solid fa-briefcase"></i> Büro / Verwaltung</span>
        </div>
      </div>
      <div class="bento__cell bento__cell--wide">
        <div class="bento__split">
          <div>
            <i class="fa-solid fa-magnifying-glass bento__cell-icon"></i>
            <h4>Vorauswahlprozess</h4>
            <p>Strukturierte Sprachinterviews, Zeugnisverifizierung, polizeiliche Führungszeugnisse und Compliance Prüfungen sichern zuverlässige Kandidaten.</p>
          </div>
          <div>
            <i class="fa-solid fa-house-circle-check bento__cell-icon"></i>
            <h4>Integrationsunterstützung</h4>
            <p>Wohnungskoordination, Relocation Vorbereitung und Online Orientierungssitzungen zu Sozialregeln, Arbeitserwartungen und Alltagsregelungen.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAMM 03 — STUDIERENDEN-ZULASSUNG -->

<section class="prg" id="admission">
  <div class="prg__stripe prg__stripe--rose"></div>
  <div class="container prg__grid">
    <!-- Left anchor -->
    <aside class="prg__anchor">
      <div class="prg__num">03</div>
      <div class="prg__icon-wrap prg__icon-wrap--rose">
        <i class="fa-solid fa-university"></i>
      </div>
      <h2 class="prg__title">Zulassungs-Support für<br /><span class="text-gradient">Internationale Studierende</span></h2>
      <p class="prg__lead">Spezialisiert auf die Studierendenzulassung aus Indien und Nepal an europäischen Universitäten. Wir vermitteln verifizierte, zulassungsbereite Kandidaten.</p>
      <a href="/services/studium-zulassung" class="btn-glow">Programm erkunden <i class="fa-solid fa-arrow-right"></i></a>
    </aside>

    <!-- Right cards -->
    <div class="prg__cards">
      <div class="info-card info-card--accent">
        <div class="info-card__head">
          <i class="fa-solid fa-file-shield"></i>
          <h3>Dokumentenprüfung</h3>
        </div>
        <p>Gründliche Verifizierung akademischer Zeugnisse und Authentifizierung durch anerkannte Stellen in Indien zur Sicherstellung der institutionellen Zuverlässigkeit.</p>
      </div>

      <div class="info-card">
        <div class="info-card__head">
          <i class="fa-solid fa-language"></i>
          <h3>Sprachvorbereitung</h3>
        </div>
        <p>Strukturiertes Training für IELTS, Deutsch (A1-B2), Französisch und Schwedisch, um die spezifischen europäischen Standards zu erfüllen.</p>
      </div>

      <div class="info-card info-card--dark">
        <div class="info-card__head">
          <i class="fa-solid fa-user-check"></i>
          <h3>Screening & Bereitschaft</h3>
        </div>
        <div class="support-pills">
          <span><i class="fa-solid fa-check"></i> Eignungsprüfung</span>
          <span><i class="fa-solid fa-microphone"></i> Motivationsgespräche</span>
          <span><i class="fa-solid fa-earth-europe"></i> Europa-Orientierung</span>
        </div>
      </div>

      <div class="info-card">
        <div class="info-card__head">
          <i class="fa-solid fa-handshake"></i>
          <h3>Hochschulpartnerschaften</h3>
        </div>
        <p>Bereitstellung einer konsistenten Pipeline vorverifizierter Bewerber, um den administrativen Aufwand zu reduzieren und Erfolgsraten zu steigern.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAMM 04 — CHANCENKARTE -->

<section class="prg" id="opportunity">
  <div class="prg__stripe prg__stripe--indigo"></div>
  <div class="container prg__grid">
    <aside class="prg__anchor">
      <div class="prg__num">04</div>
      <div class="prg__icon-wrap"><i class="fa-solid fa-passport"></i></div>
      <h2 class="prg__title">Deutsche Chancenkarte <span class="text-gradient">(Opportunity Card)</span></h2>
      <p class="prg__lead">Ein punktebasierter Aufenthaltstitel, der Nicht-EU-Fachkräften erlaubt, bis zu 12 Monate in Deutschland eine Stelle zu suchen, ohne vorheriges Jobangebot.</p>
      <a href="/contact" class="btn-glow">Jetzt Starten <i class="fa-solid fa-arrow-right"></i></a>
    </aside>
    <div class="prg__cards">
      <div class="info-card info-card--accent">
        <div class="info-card__head"><i class="fa-solid fa-list-check"></i><h3>Zugangsvoraussetzungen</h3></div>
        <ul class="check-list">
          <li>Anerkannter Hochschulabschluss oder Berufsausbildung</li>
          <li>Deutschkenntnisse (A1) oder Englischkenntnisse</li>
          <li>Einschlägige Berufserfahrung</li>
          <li>Nachgewiesene finanzielle Mittel zur Selbstversorgung</li>
          <li>Bonus: Höhere Sprachkenntnisse, Deutschland-Aufenthalt, Alter unter 35</li>
        </ul>
      </div>
      <div class="info-card">
        <div class="info-card__head"><i class="fa-solid fa-vault"></i><h3>Sperrkonto</h3></div>
        <p>Antragsteller müssen finanzielle Mittel nachweisen, in der Regel durch ein deutsches Sperrkonto. Der erforderliche Betrag liegt bei ca. <strong>12.000 €+</strong> für ein Jahr.</p>
        <div class="tag-row"><span class="tag">12.000 €+ Erforderlich</span><span class="tag">Sperrkonto Hilfe</span></div>
      </div>
      <div class="info-card">
        <div class="info-card__head"><i class="fa-regular fa-calendar"></i><h3>Aufnahmezeiten</h3></div>
        <p>Anträge können <strong>ganzjährig</strong> gestellt werden, kein fester Aufnahmezeitraum. Bearbeitungszeiten variieren je nach Botschaft. Frühe Dokumentenvorbereitung wird empfohlen.</p>
        <div class="tag-row"><span class="tag">Ganzjährig</span><span class="tag">Botschaftsabhängig</span></div>
      </div>
      <div class="info-card info-card--dark">
        <div class="info-card__head"><i class="fa-solid fa-handshake-angle"></i><h3>Unsere Zusatzleistungen</h3></div>
        <div class="support-pills">
          <span><i class="fa-solid fa-file-lines"></i> Dokumentenvorbereitung</span>
          <span><i class="fa-solid fa-vault"></i> Sperrkonto Beratung</span>
          <span><i class="fa-solid fa-magnifying-glass-location"></i> Jobsuche Orientierung</span>
          <span><i class="fa-solid fa-house"></i> Unterkunftsunterstützung</span>
          <span><i class="fa-solid fa-earth-europe"></i> Lebens-Orientierung</span>
          <span><i class="fa-solid fa-scale-balanced"></i> Deutsche Rechtsgrundlagen</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAMM 05 — FACHKRÄFTE -->

<section class="prg prg--alt" id="skilled">
  <div class="prg__stripe prg__stripe--indigo"></div>
  <div class="container">
    <header class="skilled-header">
      <div class="skilled-header__left">
        <div class="prg__num">05</div>
        <div class="prg__icon-wrap"><i class="fa-solid fa-helmet-safety"></i></div>
        <h2>Internationale <span class="text-gradient">Fachkräfte</span></h2>
        <p>Erfahrener, deutschsprechende Arbeitskräfte für Deutschlands Schiffbau, Fleischverarbeitung und industrielle Sektoren, ganzjährig verfügbar und vorgeprüft.</p>
        <a href="/contact" class="btn-glow">Anforderungen Besprechen <i class="fa-solid fa-arrow-right"></i></a>
      </div>
      <div class="skilled-header__right">
        <div class="skilled-stat"><i class="fa-solid fa-earth-europe"></i><div><strong>A2 bis B1</strong><span>Sprachniveau</span></div></div>
        <div class="skilled-stat"><i class="fa-solid fa-filter"></i><div><strong>5 Stufen</strong><span>Auswahlprozess</span></div></div>
        <div class="skilled-stat"><i class="fa-solid fa-calendar"></i><div><strong>Ganzjährig</strong><span>Verfügbarkeit</span></div></div>
      </div>
    </header>
    <div class="worker-grid">
      <div class="worker-card">
        <div class="worker-card__top">
          <div class="worker-card__icon"><i class="fa-solid fa-ship"></i></div>
          <h3>Schiffsbauprofis</h3>
          <p>Erfahrene Werftarbeiter mit starker Praxiskompetenz in Schweißen und Stahlbau.</p>
        </div>
        <ul class="worker-skills">
          <li><i class="fa-solid fa-fire-burner"></i> WIG Schweißen (141)</li>
          <li><i class="fa-solid fa-fire-burner"></i> MIG Schweißen (131)</li>
          <li><i class="fa-solid fa-fire-burner"></i> MAG Schweißen (135/136)</li>
          <li><i class="fa-solid fa-fire-burner"></i> E-Hand Schweißen (111)</li>
          <li><i class="fa-solid fa-building"></i> Stahlbaukonstruktion</li>
          <li><i class="fa-solid fa-ruler-combined"></i> Rohrfitting &amp; Rohrschweißen</li>
          <li><i class="fa-solid fa-anchor"></i> Rumpfbauunterstützung</li>
          <li><i class="fa-solid fa-gears"></i> Mechanische Montage</li>
          <li><i class="fa-solid fa-drafting-compass"></i> Blaupausenlesen</li>
          <li><i class="fa-solid fa-helmet-safety"></i> Arbeitssicherheit</li>
        </ul>
      </div>
      <div class="worker-card worker-card--featured">
        <div class="worker-card__top">
          <div class="worker-card__icon"><i class="fa-solid fa-utensils"></i></div>
          <h3>Metzger &amp; Fleischverarbeitung</h3>
          <p>Ausgebildete Fachkräfte mit Industrieerfahrung in Hygieneumgebungen.</p>
        </div>
        <ul class="worker-skills">
          <li><i class="fa-solid fa-industry"></i> Schlachthausbetrieb</li>
          <li><i class="fa-solid fa-scissors"></i> Industrielles Schneiden</li>
          <li><i class="fa-solid fa-drumstick-bite"></i> Ausbeinarbeit</li>
          <li><i class="fa-solid fa-boxes-packing"></i> Portionsschnitt &amp; Verpackung</li>
          <li><i class="fa-solid fa-pump-medical"></i> HACCP Hygiene</li>
          <li><i class="fa-solid fa-snowflake"></i> Kühlraumhandhabung</li>
          <li><i class="fa-solid fa-conveyor-belt"></i> Fließbandverarbeitung</li>
          <li><i class="fa-solid fa-shield-halved"></i> Messersicherheit</li>
          <li><i class="fa-solid fa-clipboard-check"></i> Lebensmittelsicherheit</li>
        </ul>
      </div>
      <div class="worker-card">
        <div class="worker-card__top">
          <div class="worker-card__icon"><i class="fa-solid fa-industry"></i></div>
          <h3>Industriearbeiter</h3>
          <p>Vielseitige Kandidaten mit Erfahrung in Fertigung, Logistik und Technik.</p>
        </div>
        <ul class="worker-skills">
          <li><i class="fa-solid fa-microchip"></i> Maschinenbedienung</li>
          <li><i class="fa-solid fa-microchip"></i> CNC Hilfstätigkeiten</li>
          <li><i class="fa-solid fa-conveyor-belt"></i> Fließbandfertigung</li>
          <li><i class="fa-solid fa-warehouse"></i> Lagerlogistik</li>
          <li><i class="fa-solid fa-truck-ramp-box"></i> Staplererfahrung</li>
          <li><i class="fa-solid fa-magnifying-glass-chart"></i> Qualitätskontrolle</li>
          <li><i class="fa-solid fa-boxes-packing"></i> Verpackung &amp; Versand</li>
          <li><i class="fa-solid fa-hammer"></i> Metallbearbeitungshilfe</li>
          <li><i class="fa-solid fa-screwdriver-wrench"></i> Wartungshelfer</li>
        </ul>
      </div>
    </div>
    <div class="readiness-bar">
      <div class="readiness-bar__icon"><i class="fa-solid fa-language"></i></div>
      <div class="readiness-bar__text">
        <strong>Sprachliche &amp; Berufliche Bereitschaft</strong>
        <p>Alle Kandidaten erhalten eine Deutschsprachvorbereitung (A2 bis B1 je nach Beruf) sowie eine Arbeitsplatzorientierung zur Unterstützung der Integration in deutschen Industrieteams.</p>
      </div>
      <a href="/contact" class="btn-glow btn-glow--sm">Anfragen</a>
    </div>
  </div>
</section>

<!-- 5-STUFEN SCREENING -->
<section class="screening">
  <div class="container">
    <div class="screening__header">
      <span class="section-badge"><i class="fa-solid fa-filter"></i> Unser Prozess</span>
      <h2>Der 5 Stufen <span class="text-gradient">Auswahlprozess</span></h2>
      <p>Jeder Kandidat durchläuft unsere strenge Prüfung, bevor er einem Arbeitgeber präsentiert wird, Qualität, Compliance, und Vertrauen.</p>
    </div>
    <div class="screening__track">
      <div class="track__step">
        <div class="track__bubble"><i class="fa-solid fa-language"></i></div>
        <div class="track__connector"></div>
        <div class="track__card"><span class="track__num">01</span><h4>Sprachkenntnischeck</h4><p>Strukturierte Deutsch Interviews: Sprache, Verständnis, Schreiben und kontextuelles Vokabular von A1 bis B2.</p></div>
      </div>
      <div class="track__step">
        <div class="track__bubble"><i class="fa-solid fa-file-contract"></i></div>
        <div class="track__connector"></div>
        <div class="track__card"><span class="track__num">02</span><h4>Dokumentenverifizierung</h4><p>Alle Diplome und Berufsqualifikationen werden gegen deutsche und EU-Anerkennungsrahmen geprüft.</p></div>
      </div>
      <div class="track__step">
        <div class="track__bubble"><i class="fa-solid fa-shield-halved"></i></div>
        <div class="track__connector"></div>
        <div class="track__card"><span class="track__num">03</span><h4>Führungszeugnis</h4><p>Polizeiliches Führungszeugnis der letzten 10 Jahre. Nulltoleranzpolitik bei Vorstrafen.</p></div>
      </div>
      <div class="track__step">
        <div class="track__bubble"><i class="fa-solid fa-wallet"></i></div>
        <div class="track__connector"></div>
        <div class="track__card"><span class="track__num">04</span><h4>Finanzielle Hintergrundprüfung</h4><p>Wir prüfen den finanziellen Hintergrund und klären ab dass keine offene Schulden in Indien bestehen.</p></div>
      </div>
      <div class="track__step">
        <div class="track__bubble track__bubble--final"><i class="fa-solid fa-thumbs-up"></i></div>
        <div class="track__card"><span class="track__num">05</span><h4>Compliance Freigabe</h4><p>Abschließende Prüfung der Einwanderungseignung, Punktebewertung und arbeitgeberspezifischer Anforderungen.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-strip">
  <div class="container cta-strip__inner">
    <div>
      <h2>Bereit, Ihr <span class="text-gradient">Team aufzubauen?</span></h2>
      <p>Ob Chancenkarte-Kandidaten, Auszubildende, Pflegekräfte oder Industriefachkräfte, wir haben die richtige Talent Pipeline für Sie.</p>
    </div>
    <div class="cta-strip__btns">
      <a href="/contact" class="btn btn-primary">Mit Experten Sprechen</a>
      <a href="/about" class="btn btn-outline">Über Scandic Roots</a>
    </div>
  </div>
</section>

</Layout>

<style>
:root { --indigo:#11184C;--rose:#B23D69;--violet:#2d1b5e;--indigo-mid:#1a2269;--white:#fff;--off:#f7f8ff;--muted:#4A5568; }

.sv-hero { position:relative;min-height:100vh;background:#09091a;display:flex;align-items:center;justify-content:center;overflow:hidden;text-align:center; }
